<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Custom App Bar with only bottom shadow -->
    <FrameLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="15dp"
        android:background="@drawable/top_bar_shadow">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="0dp"
            android:paddingEnd="20dp">

            <!-- Back Arrow -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_back_arrow"
                android:contentDescription="Back" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Forget password"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/loginButton"
        android:layout_below="@id/topBar"
        android:layout_marginTop="8dp"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Info Text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter your email and we will send you a OTP code to reset your password "
                android:textColor="#000000"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <!-- Email Display -->


            <!-- Input Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textSize="14sp"
                android:textColor="#000000"
                android:layout_marginBottom="4dp" />

            <!-- Email Input Field -->
            <EditText
                android:id="@+id/emailEditText"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="john@email.com"
                android:background="@drawable/rounded_edittext"
                android:inputType="textEmailAddress"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#999999"
                android:layout_marginBottom="16dp" />

            <!-- Timer Text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resend code in 04:24"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp" />

            <!-- Resend Message -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Did you don’t get code? "
                android:textColor="#000000"
                android:textSize="14sp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp" />

            <!-- Resend Code Button -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resend Code"
                android:textColor="#F44C4C"
                android:textSize="14sp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="32dp" />
        </LinearLayout>
    </ScrollView>

    <!-- Verify Button at Bottom -->
    <Button
        android:id="@+id/loginButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Verify"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF4B4B"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp" />

</RelativeLayout>
