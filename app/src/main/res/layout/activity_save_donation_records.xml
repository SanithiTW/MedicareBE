<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@android:color/white">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back_arrow" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Record Blood Donation"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"/>
    </LinearLayout>

    <!-- NIC Input -->
    <EditText
        android:id="@+id/nicInput"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Enter NIC"
        android:background="@drawable/rounded_edittext"
        android:paddingHorizontal="12dp"
        android:textColor="@color/black"/>

    <!-- Search Button -->
    <Button
        android:id="@+id/searchButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Search"
        android:layout_marginTop="12dp"
        android:backgroundTint="#FF4B4B"
        android:textColor="#FFFFFF"/>

    <!-- Result Section -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp">

        <LinearLayout
            android:id="@+id/reservationContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

    <!-- Donation Input Section -->
    <EditText
        android:id="@+id/donationAmount"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Enter donated amount (ml)"
        android:background="@drawable/rounded_edittext"
        android:paddingHorizontal="12dp"
        android:layout_marginTop="12dp"
        android:inputType="number"
        android:visibility="gone"
        android:textColor="@color/black"/>

    <Button
        android:id="@+id/confirmDonation"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Confirm Donation"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF50"
        android:layout_marginTop="8dp"
        android:visibility="gone"/>
</LinearLayout>
