<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Top Bar with Back Button and Title -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/top_bar_shadow"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_back_arrow"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Super Admin"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Super Admin"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Please enter all the required admin credentials below."
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_marginBottom="24dp" />

            <!-- Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textSize="14sp"
                android:textColor="#000000" />
            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Ashen Kavinda"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#999999"
                android:layout_marginBottom="16dp" />

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textSize="14sp"
                android:textColor="#000000" />
            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="admin@email.com"
                android:inputType="textEmailAddress"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#999999"
                android:layout_marginBottom="16dp" />

            <!-- Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textSize="14sp"
                android:textColor="#000000" />
            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="********"
                android:inputType="textPassword"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#999999"
                android:layout_marginBottom="16dp" />

            <!-- Mobile -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mobile Number"
                android:textSize="14sp"
                android:textColor="#000000" />
            <EditText
                android:id="@+id/etMobile"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="0771234567"
                android:inputType="phone"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#999999"
                android:layout_marginBottom="16dp" />

            <!-- Province -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Province"
                android:textSize="14sp"
                android:textColor="#000000" />
            <EditText
                android:id="@+id/etProvince"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Southern Province"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#999999"
                android:layout_marginBottom="24dp" />

            <!-- Confirm Button -->
            <Button
                android:id="@+id/btnCreateAdmin"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Create Super Admin"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF4B4B"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>
</RelativeLayout>
