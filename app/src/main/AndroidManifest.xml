<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DONORlk"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".controllers.LoginController"
            android:exported="false" />

        <activity
            android:name=".controllers.RegistrationController"
            android:exported="false" />

        <activity
            android:name=".controllers.ProfileSetupController"
            android:exported="false" />

        <activity
            android:name=".controllers.ForgotPasswordController"
            android:exported="false" />

        <activity
            android:name=".controllers.VerificationController"
            android:exported="false" />

        <activity
            android:name=".controllers.HomePageController"
            android:exported="false" />

        <activity
            android:name=".controllers.DonationHistoryController"
            android:exported="false" />

        <activity
            android:name=".controllers.DonationFormController"
            android:exported="false" />

        <activity android:name=".CreateAdminActivity" />
        <activity android:name=".controllers.AdminDashboardController" />
      
        <activity android:name=".RecordDonationActivity" />


    </application>
</manifest>